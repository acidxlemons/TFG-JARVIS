# ============================================
# APLICACIÓN
# ============================================
APP_NAME=JARVIS RAG System
APP_URL=https://YOUR_SERVER_IP
ENVIRONMENT=local

# ============================================
# AZURE OIDC (SSO) + SharePoint
# ============================================
AZURE_TENANT_ID=YOUR_AZURE_TENANT_ID
AZURE_CLIENT_ID=YOUR_AZURE_CLIENT_ID
AZURE_CLIENT_SECRET=CHANGE_ME

# Multi-site SharePoint (habilitar sincronización) - dejar en false para usar solo RAG local
SHAREPOINT_MULTI_SITE=false

# Ruta al fichero de configuración de sitios SharePoint
# Si no tienes SharePoint, deja el valor por defecto (plantilla vacía)
# Si tienes config real: SHAREPOINT_SITES_FILE=./config/sharepoint_sites.json
SHAREPOINT_SITES_FILE=./config/sharepoint_sites_template.json

# ============================================
# BASE DE DATOS
# ============================================
POSTGRES_DB=rag_system
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=CHANGE_ME

# ============================================
# ALMACENAMIENTO
# ============================================
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME

# ============================================
# LITELLM
# ============================================
LITELLM_MASTER_KEY=CHANGE_ME

# ============================================
# SHAREPOINT (vacío para no sincronizar en local)
# ============================================
SHAREPOINT_SITE_ID=
SHAREPOINT_FOLDER_PATH=Shared Documents/RAG
WEBHOOK_SECRET=CHANGE_ME

# ============================================
# OCR & PROCESAMIENTO
# ============================================
OCR_NUM_WORKERS=6
OCR_USE_GPU=true
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# MONITOREO
# ============================================
GRAFANA_PASSWORD=CHANGE_ME

# ============================================
# SEGURIDAD
# ============================================
JWT_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# ============================================
# BACKUPS
# ============================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=rag-backups

# ============================================
# TENANT por defecto (multi-tenant opcional)
# ============================================
DEFAULT_TENANT_ID=tenant-default

# ============================================
# MINIO bucket para documentos
# ============================================
MINIO_BUCKET=documents

# Formato de logs
LOG_FORMAT=json  
LOG_LEVEL=INFO
