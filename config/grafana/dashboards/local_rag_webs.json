{
    "id": null,
    "uid": "local-rag-webs",
    "title": "📚 Local RAG & Web Scraping",
    "description": "Monitorización del sistema RAG local (documentos + webs indexadas)",
    "tags": [
        "rag",
        "webs",
        "local",
        "scraping"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "title": "🟢 Backend Status",
            "description": "Estado del servicio RAG",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "up{job=\"rag-backend\"}",
                    "legendFormat": "Backend",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "colorMode": "background",
                "graphMode": "none"
            },
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            }
                        }
                    ],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 2,
            "title": "📄 Documentos Indexados",
            "description": "Total de documentos en colección 'documents'",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 0
            },
            "targets": [
                {
                    "expr": "documents_indexed_total",
                    "legendFormat": "Documentos",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "colorMode": "value",
                "graphMode": "area"
            },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    },
                    "unit": "short"
                }
            }
        },
        {
            "id": 3,
            "title": "🌐 Webs Indexadas",
            "description": "Total de URLs en colección 'webs'",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "webs_indexed_total",
                    "legendFormat": "Webs",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "colorMode": "value",
                "graphMode": "area"
            },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "purple",
                                "value": null
                            }
                        ]
                    },
                    "unit": "short"
                }
            }
        },
        {
            "id": 4,
            "title": "🔍 Búsquedas RAG/min",
            "description": "Tasa de búsquedas por minuto",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(rate(rag_search_requests_total[1m])) * 60",
                    "legendFormat": "Búsquedas/min",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "colorMode": "value",
                "graphMode": "area"
            },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    },
                    "unit": "short"
                }
            }
        },
        {
            "id": 99,
            "title": "📊 Actividad RAG",
            "type": "row",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 4
            }
        },
        {
            "id": 5,
            "title": "📈 Búsquedas por Intent",
            "description": "Distribución de búsquedas por tipo de intent",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 5
            },
            "targets": [
                {
                    "expr": "sum(rate(rag_search_requests_total[5m])) by (intent)",
                    "legendFormat": "{{intent}}",
                    "refId": "A"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth",
                        "fillOpacity": 20,
                        "lineWidth": 2
                    },
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "reqps"
                }
            }
        },
        {
            "id": 6,
            "title": "⏱️ Latencia RAG (p50, p95)",
            "description": "Percentiles de latencia de búsqueda",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 5
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum(rate(rag_search_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "p50",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.95, sum(rate(rag_search_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "p95",
                    "refId": "B"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth",
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "s"
                }
            }
        },
        {
            "id": 7,
            "title": "✅❌ Hits vs Misses",
            "description": "Búsquedas con/sin resultados",
            "type": "piechart",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 0,
                "y": 13
            },
            "targets": [
                {
                    "expr": "sum(increase(rag_search_hits_total[1h]))",
                    "legendFormat": "Hits",
                    "refId": "A"
                },
                {
                    "expr": "sum(increase(rag_search_misses_total[1h]))",
                    "legendFormat": "Misses",
                    "refId": "B"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "right"
                },
                "pieType": "donut"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "id": 8,
            "title": "🎯 Confianza Promedio",
            "description": "Score promedio de resultados",
            "type": "gauge",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 6,
                "y": 13
            },
            "targets": [
                {
                    "expr": "avg(rag_result_confidence)",
                    "legendFormat": "Confianza",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                }
            },
            "fieldConfig": {
                "defaults": {
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.5
                            },
                            {
                                "color": "green",
                                "value": 0.7
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 98,
            "title": "🕷️ Web Scraping",
            "type": "row",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 19
            }
        },
        {
            "id": 9,
            "title": "🕷️ Scrapes por Hora",
            "description": "URLs scrapeadas por hora",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 20
            },
            "targets": [
                {
                    "expr": "sum(rate(web_scrapes_total[5m])) by (status) * 3600",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "bars",
                        "fillOpacity": 80,
                        "lineWidth": 1
                    },
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "short"
                }
            }
        },
        {
            "id": 10,
            "title": "⏱️ Duración Scraping",
            "description": "Tiempo promedio de scraping",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 20
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum(rate(web_scrapes_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "p50",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "min": 0,
                    "max": 30,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 20
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 11,
            "title": "⚠️ Errores Scraping",
            "description": "Errores de scraping por tipo",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 20
            },
            "targets": [
                {
                    "expr": "sum(increase(scrape_errors_total[1h])) by (error_type)",
                    "legendFormat": "{{error_type}}",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "colorMode": "value",
                "graphMode": "none"
            },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 5
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 12,
            "title": "📊 Distribución por Modo",
            "description": "Scrapes index vs analyze",
            "type": "piechart",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 24
            },
            "targets": [
                {
                    "expr": "sum(increase(web_scrapes_total[1h])) by (mode)",
                    "legendFormat": "{{mode}}",
                    "refId": "A"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "right"
                },
                "pieType": "pie"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        }
    ],
    "templating": {
        "list": []
    },
    "annotations": {
        "list": []
    }
}